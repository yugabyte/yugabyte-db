# Copy to /etc/yugabyte/byoc-api-proxy/byoc-api-proxy.env and adjust values.
# chmod 600 /etc/yugabyte/byoc-api-proxy/byoc-api-proxy.env

# Java runtime. Override when co-installed with YBA installer, for example:
# JAVA_HOME=/opt/yugabyte/software/yba-2.31.0.0-b0/jdk-17.0.7+7-jre
JAVA_HOME=/opt/yugabyte/jdk-17

# Target YBA instance
YBA_UUID=
YBA_BASE_URL=https://127.0.0.1:9443/api

# Aeon / proxied API server (queued request source)
PROXIED_APP_BASE_URL=https://api.example.com/api
PROXIED_APP_READ_TIMEOUT=PT30S
PROXIED_APP_POLL_BATCH_SIZE=10

# Authentication to proxied_app (service_account or api_key)
PROXIED_APP_AUTH_TYPE=service_account
SERVICE_ACCOUNT_EMAIL=
SERVICE_ACCOUNT_PASSWORD=
SERVICE_ACCOUNT_JWT_REFRESH_INTERVAL=PT10H
# API_KEY=

# Optional: non-local logging format (see logback-spring.xml)
# YBCLOUD_CONF_ENVIRONMENT=PROD
