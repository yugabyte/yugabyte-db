set -euo pipefail

print_help() {
  cat <<EOT
Usage: ${0##*/} [<options>]
Options:
  -p, --logs_disk_percent_max <logsdiskpercent>
    max percentage of disk to use for logs (default=10).
  -z, --gzip_only
    only gzip files, don't purge.
  -h, --help
    Show usage.
  -s, --postgres_max_log_size <size in mb>
    max size of disk to use for postgres logs (default=100mb)
  -t, --logs_purge_threshold <size in gb>
    threshold of disk space to use for server logs (default=10gb)
EOT
}

gzip_only=false
YB_HOME_DIR=({{ yb_home_dir }})
preserve_audit_logs=false
ycql_audit_log_level=NONE
# Retention (in days) for archived audit logs.
# 0 (the default) disables the dedicated audit-log retention pipeline and keeps
# the previous size-based purge behavior.
ysql_audit_log_retention_days=0
ycql_audit_log_retention_days=0

logs_disk_percent_max=10
postgres_max_log_size_kb=$((100 * 1000))
ysql_conn_mgr_max_log_size_kb=$((100 * 1000))
logs_purge_threshold_kb=$((10 * 1000000))

while [[ $# -gt 0 ]]; do
  case "$1" in
    -p|--logs_disk_percent_max)
      logs_disk_percent_max=$2
      shift
    ;;
    -s|--postgres_max_log_size)
      postgres_max_log_size_kb=$(($2 * 1000))
      shift
    ;;
    -t|--logs_purge_threshold)
      logs_purge_threshold_kb=$(($2 * 1000000))
      shift
    ;;
    -z|--gzip_only)
      gzip_only=true
    ;;
    -h|--help)
      print_help
      exit 0
    ;;
    *)
      echo "Invalid option: $1" >&2
      print_help
      exit 1
  esac
  shift
done

USER=${USER:-$(whoami)}
if [[ "$(id -u)" != "0" && "$USER" != "yugabyte" ]]; then
  echo "This script must be run as root or yugabyte" >&2
  exit 1
fi

if [[ $logs_disk_percent_max -lt 1 || $logs_disk_percent_max -gt 100 ]]; then
  echo "--logs_disk_percent_max needs to be [1, 100]" >&2
  exit 1
fi

if [[ $logs_purge_threshold_kb -lt 1000000 ]]; then
  echo "--logs_purge_threshold needs to be at least 1 GB"
  exit 1
fi

# half for tserver and half for master.
logs_disk_percent_max=$(($logs_disk_percent_max / 2))
logs_purge_threshold_kb=$(($logs_purge_threshold_kb / 2))

# Get total size of disk in kb and then compute permitted usage for the log files.
# As we need to calculate size once we use cores dir -
# as it's mounted from the same volume as master/tserver log dirs
disk_size_kb=$(df -k $YB_HOME_DIR/cores | awk 'NR==2{print $2}')
percent_disk_usage_kb=$(($disk_size_kb * $logs_disk_percent_max / 100))
permitted_disk_usage_kb=$([ $percent_disk_usage_kb -le $logs_purge_threshold_kb ] && \
   echo "$percent_disk_usage_kb" || echo "$logs_purge_threshold_kb")

# half for plain text logs in case audit logs export is enabled -
# to give some time for exporter to read logs
permitted_disk_usage_plain_kb=$((permitted_disk_usage_kb / 2))
postgres_max_plain_log_size_kb=$((postgres_max_log_size_kb / 2))

# Read audit logs cleanup settings
if [ -e "$YB_HOME_DIR/otel-collector/log_cleanup_env" ]
then
  source "$YB_HOME_DIR/otel-collector/log_cleanup_env"
fi

# Per-file audit-archive helper. Invoked from gzip_log_file() right before
# each gzip call so that we either (a) successfully persist the audit slice
# into audit/<flavor>/ AND then gzip the source, or (b) bail out without
# gzipping when audit archiving failed - guaranteeing that we never delete
# audit content that has not been safely captured.
#
# Extracts every line of $src_file matching $audit_pattern (fixed string) into
# $audit_dir/<basename>.audit.log.gz. Idempotent: a completed .gz
# short-circuits the call. A leftover plain .audit.log is treated as a
# previous failed attempt, discarded, and the extraction is retried.
# Returns non-zero only when the gzip of the extracted slice fails (the grep
# itself is allowed to return no matches).
#
# Currently used with two audit flavors:
#   YSQL (pgaudit):  "LOG:  AUDIT:"
#   YCQL:            "] AUDIT: user:"  (glog prefix's "]" plus the AUDIT
#                                       prefix emitted in audit_logger.cc)
archive_audit_lines() {
  local src_file=$1
  local audit_dir=$2
  local audit_pattern=$3
  local flavor_label=$4
  local dst_base
  dst_base=$(basename "$src_file")
  local dst_plain="$audit_dir/${dst_base}.audit.log"
  local dst_gz="${dst_plain}.gz"
  if [ -e "$dst_gz" ]; then
    return 0
  fi
  mkdir -p "$audit_dir" || return 1
  if [ -e "$dst_plain" ]; then
    echo "Discarding stale audit slice $dst_plain from a previous failed run"
    rm -f "$dst_plain"
  fi
  # grep -aF: -a treats binary as text, -F matches the pattern as a fixed
  # string (no regex). Missing matches return 1, which is fine here.
  grep -aF "$audit_pattern" "$src_file" > "$dst_plain" 2>/dev/null || true
  if [ ! -s "$dst_plain" ]; then
    rm -f "$dst_plain"
    return 0
  fi
  if ! gzip "$dst_plain"; then
    rm -f "$dst_plain" "$dst_gz"
    return 1
  fi
  echo "Archived $flavor_label audit lines from $src_file to $dst_gz"
  return 0
}

# Audit-pattern constants. Sourced once at the top of the per-flavor archive
# wrappers so call sites stay short.
readonly YSQL_AUDIT_PATTERN='LOG:  AUDIT:'
readonly YCQL_AUDIT_PATTERN='] AUDIT: user:'

archive_postgres_audit_lines() {
  archive_audit_lines "$1" "$2" "$YSQL_AUDIT_PATTERN" "YSQL"
}

archive_ycql_audit_log() {
  archive_audit_lines "$1" "$2" "$YCQL_AUDIT_PATTERN" "YCQL"
}

# Single chokepoint for gzipping a YB log file. If $archive_fn is non-empty,
# it is invoked first to persist an audit-only copy under $audit_dir; if that
# fails the source is left as-is so the data is not lost. On success the
# source file is gzipped in place. Returns non-zero (without aborting under
# set -e) when either the archive step or the gzip itself fails.
gzip_log_file() {
  local src_file=$1
  local archive_fn=$2
  local audit_dir=$3
  if [ -n "$archive_fn" ]; then
    if ! "$archive_fn" "$src_file" "$audit_dir"; then
      echo "WARN: audit archive failed for $src_file - skipping gzip to avoid data loss" >&2
      return 1
    fi
  fi
  echo "Compressing file $src_file"
  if ! gzip "$src_file"; then
    echo "WARN: gzip failed for $src_file" >&2
    return 1
  fi
  return 0
}

delete_or_gzip_files() {
  set -f
  local log_dir=$1
  local usage_regex=$2
  local files_regex=$3
  local permitted_usage=$4
  local operation=$5
  # Optional audit-archival hook: function name + destination directory.
  local archive_fn=${6:-}
  local audit_dir=${7:-}
  local logs_disk_usage_bytes=$(find "$log_dir" -type f -name $usage_regex -print0 | \
    xargs -0 -r stat -c '%s' | \
    awk '{sum+=$1;}END{print sum;}')
  if [ -z $logs_disk_usage_bytes ]; then
    logs_disk_usage_bytes=0
  fi
  local logs_disk_usage_kb=$(($logs_disk_usage_bytes / 1000 ))
  echo "Permitted disk usage for $usage_regex files in kb: $permitted_usage"
  echo "Disk usage by $usage_regex files in kb: $logs_disk_usage_kb"
  # get all the files to process.
  local log_files=$(find "$log_dir" -type f -name $files_regex -print0 | \
    xargs -0 -r stat -c '%Y %n' | \
    sort | awk '{print $2}')
  for file in $log_files; do
    # If usage exceeds permitted, delete the old gz files.
    if [ $logs_disk_usage_kb -gt $permitted_usage ]; then
      local file_size=$(du -k $file | awk '{print $1}')
      logs_disk_usage_kb=$(($logs_disk_usage_kb-$file_size))
      if [ "$operation" == "delete" ]; then
        echo "Delete file $file"
        rm "$file"
      else
        if ! gzip_log_file "$file" "$archive_fn" "$audit_dir"; then
          # Restore the budget; the file is still on disk.
          logs_disk_usage_kb=$(($logs_disk_usage_kb+$file_size))
          continue
        fi
        local new_file_size=$(du -k $file.gz | awk '{print $1}')
        logs_disk_usage_kb=$(($logs_disk_usage_kb+$new_file_size))
      fi
    else
      break
    fi
  done
}

process_plain_files()
{
  set -f
  local log_dir=$1
  local log_regex=$2
  local allowed_disk_usage_kb=$3
  # Optional audit-archival hook: function name + destination directory.
  local archive_fn=${4:-}
  local audit_dir=${5:-}
  # Using print0 since printf is not supported on all UNIX systems.
  # xargs -0 -r stat -c '%Y %n' outputs: [unix time in millisecs] [name of file]
  find_non_gz_files="find $log_dir -type f -name \
  $log_regex -print0 | xargs -0 -r stat -c '%Y %n' | sort | awk '{print \$2}'"
  non_gz_file_count=$(eval "$find_non_gz_files" | wc -l)

  # gzip files if we have more than 1
  if [ $non_gz_file_count -gt 1 ]; then
    if [ $allowed_disk_usage_kb -gt 0 ]; then
      delete_or_gzip_files $log_dir "$log_regex" "$log_regex" \
        $permitted_disk_usage_plain_kb "gzip" "$archive_fn" "$audit_dir"
    else
      files_to_gzip=$(eval "$find_non_gz_files" | head -n$(($non_gz_file_count - 1)))
      for file in $files_to_gzip; do
        gzip_log_file "$file" "$archive_fn" "$audit_dir" || true
      done
    fi
  fi
}

# Delete audit-log archives older than the configured retention window. Also
# cleans up any abandoned plain .audit.log scratch files left behind by a
# previously-interrupted archive_*() invocation so they do not accumulate.
purge_audit_dir() {
  set -f
  local audit_dir=$1
  local retention_days=$2
  if [ ! -d "$audit_dir" ]; then
    return
  fi
  echo "Purging audit archives older than $retention_days day(s) in $audit_dir"
  find "$audit_dir" -type f -name '*.gz' -mtime +"$retention_days" -print -delete \
    2>/dev/null || true
  # Any *.audit.log plain file present for more than a day must be from a
  # failed run that the live retry path never had a chance to retry; reap it.
  find "$audit_dir" -type f -name '*.audit.log' -mtime +0 -print -delete \
    2>/dev/null || true
}

server_types="master tserver"
daemon_types=""
for server_type in $server_types; do
  if [[ -d "$YB_HOME_DIR/$server_type/logs" ]]; then
    daemon_types="${daemon_types} $server_type"
  fi
done
log_levels="INFO ERROR WARNING FATAL"
ycql_audit_retention_active=false
if [ "$ycql_audit_log_retention_days" -gt 0 ] && [ "$ycql_audit_log_level" != "NONE" ]; then
  ycql_audit_retention_active=true
fi
for daemon_type in $daemon_types; do
  YB_LOG_DIR="$YB_HOME_DIR/$daemon_type/logs/"
  ysql_audit_dir="$YB_LOG_DIR/audit/ysql"
  ycql_audit_dir="$YB_LOG_DIR/audit/ycql"

  for level in $log_levels; do
    log_regex="yb-$daemon_type*log.$level* ! -name *.gz"

    plain_logs_disk_usage_kb=0
    if [ "$daemon_type" == "tserver" ] && [ $preserve_audit_logs == true ] \
    && [ "$level" == "$ycql_audit_log_level" ]; then
      plain_logs_disk_usage_kb=$permitted_disk_usage_plain_kb
    fi

    # When YCQL audit retention is active, archive each tserver audit-level
    # log into audit/ycql/ as part of the same gzip step. A failure to
    # archive will skip the gzip so the source data is preserved on disk.
    ycql_archive_fn=""
    ycql_archive_audit_dir=""
    if [ "$daemon_type" == "tserver" ] && [ "$ycql_audit_retention_active" == true ] \
    && [ "$level" == "$ycql_audit_log_level" ]; then
      ycql_archive_fn="archive_ycql_audit_log"
      ycql_archive_audit_dir="$ycql_audit_dir"
    fi

    process_plain_files "$YB_LOG_DIR" "$log_regex" $plain_logs_disk_usage_kb \
      "$ycql_archive_fn" "$ycql_archive_audit_dir"
  done

  # Audit-extraction hook for postgres logs. Wires through both the size-based
  # gzip path inside process_plain_files and the "older than 24h" loop below
  # so every postgres log gzip is preceded by an audit extraction; if the
  # extraction fails the gzip is skipped to avoid losing audit content.
  pg_archive_fn=""
  pg_archive_audit_dir=""
  if [ "$daemon_type" == "tserver" ] && [ "$ysql_audit_log_retention_days" -gt 0 ]; then
    pg_archive_fn="archive_postgres_audit_lines"
    pg_archive_audit_dir="$ysql_audit_dir"
  fi

  plain_postgres_log="postgres*log ! -name *.gz"
  plain_pg_logs_disk_usage_kb=0
  if [ $preserve_audit_logs == true ]; then
    plain_pg_logs_disk_usage_kb=$postgres_max_plain_log_size_kb
    # When audit log export is enabled the budget-based logic below defers gzipping
    # plain postgres logs as long as the cumulative size stays under the budget, which
    # can keep individual log files plain indefinitely. Always gzip postgres logs
    # that have not been modified in the last 24 hours so exporters get a full day
    # to consume each log but plain logs don't accumulate forever.
    while IFS= read -r -d '' old_pg_log; do
      echo "Compressing postgres log not modified in the last day: $old_pg_log"
      gzip_log_file "$old_pg_log" "$pg_archive_fn" "$pg_archive_audit_dir" || true
    done < <(find "$YB_LOG_DIR" -maxdepth 1 -type f -name 'postgresql-*.log' \
                  ! -name '*.gz' -mmin +1440 -print0 2>/dev/null)
  fi
  process_plain_files "$YB_LOG_DIR" "$plain_postgres_log" $plain_pg_logs_disk_usage_kb \
    "$pg_archive_fn" "$pg_archive_audit_dir"

  plain_ysql_conn_mgr_log="ysql-conn-mgr*log* ! -name *.gz"
  plain_ysql_conn_mgr_logs_disk_usage_kb=0
  process_plain_files "$YB_LOG_DIR" "$plain_ysql_conn_mgr_log" $plain_ysql_conn_mgr_logs_disk_usage_kb

  if [ "$gzip_only" == false ]; then
    server_log="yb-$daemon_type*log.*"
    postgres_log="postgres*log*"
    ysql_conn_mgr_log="ysql-conn-mgr*log*"
    delete_or_gzip_files "$YB_LOG_DIR" "$server_log" "$server_log.gz" \
      "$permitted_disk_usage_kb" "delete"
    delete_or_gzip_files "$YB_LOG_DIR" "$postgres_log" "$postgres_log.gz" \
      "$postgres_max_log_size_kb" "delete"
    delete_or_gzip_files "$YB_LOG_DIR" "$ysql_conn_mgr_log" "$ysql_conn_mgr_log.gz" \
      "$ysql_conn_mgr_max_log_size_kb" "delete"
  fi

  if [ "$daemon_type" == "tserver" ]; then
    if [ "$ysql_audit_log_retention_days" -gt 0 ]; then
      purge_audit_dir "$ysql_audit_dir" "$ysql_audit_log_retention_days"
    fi
    if [ "$ycql_audit_log_retention_days" -gt 0 ]; then
      purge_audit_dir "$ycql_audit_dir" "$ycql_audit_log_retention_days"
    fi
  fi
done
