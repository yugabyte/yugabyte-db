#!/usr/bin/env bash

# Wrapper that places the tserver process into the yugabyte-db CPU cgroup
# before exec on the real binary for cgroup v1 and cgroup v2 systemd version < 254.
# Installed only when configure_cgroup is enabled; the systemd unit's ExecStart
# points here instead of yb-tserver directly.

set -euo pipefail

find_yb_user_home() {
  if id -u "yugabyte" >/dev/null 2>&1; then
    yb_user_home=$(getent passwd yugabyte | cut -d: -f6 2>&1)
    if [[ -z "$yb_user_home" ]]; then
      echo "FATAL: Could not find home directory for user yugabyte"
      exit 1
    else
      echo "$yb_user_home"
    fi
  else
    echo "FATAL: User yugabyte does not exist"
    exit 1
  fi
}

YB_USER_HOME=$(find_yb_user_home)
STATE_DIR="${YB_USER_HOME}/.yugabyte"
CG_NAME="yugabyte-db"

# Read cgroup type from state file
CGROUP_TYPE="unknown"
[ -f "${STATE_DIR}/cgroup_type" ] && CGROUP_TYPE=$(tr -d '\r\n' < "${STATE_DIR}/cgroup_type")

setup_v1() {
  # Read cpu cgroup path from state file
  local cpu="/sys/fs/cgroup/cpu"
  [ -f "${STATE_DIR}/cgroup_v1_cpu" ] && cpu=$(tr -d '\r\n' < "${STATE_DIR}/cgroup_v1_cpu")
  # Move process into yugabyte-db cgroup
  local leaf="${cpu}/${CG_NAME}"
  for f in "${leaf}/tasks" "${leaf}/cgroup.procs"; do
    [ -f "$f" ] && echo $$ > "$f"
  done
}

setup_v2() {
  local self_cg
  self_cg=$(grep -m1 '^0:' /proc/$$/cgroup | cut -d: -f3)

  local fs="/sys/fs/cgroup"

  # DelegateSubgroup=yugabyte-db (systemd >= 254) handles process placement
  # inside the sub-cgroup — nothing to do.
  if [[ "${self_cg##*/}" == "$CG_NAME" ]]; then
    local parent_cg="${self_cg%/*}"
    # We turn on the cpu control in the parent
    if ! grep -q "cpu" "${fs}${parent_cg}/cgroup.subtree_control"; then
      echo "+cpu" > "${fs}${parent_cg}/cgroup.subtree_control" 2>/dev/null || true
    fi
    return 0
  fi

  local subgroup="${self_cg}/${CG_NAME}"
  mkdir -p "${fs}${subgroup}"
  echo $$ > "${fs}${subgroup}/cgroup.procs"
  echo "+cpu" > "${fs}${self_cg}/cgroup.subtree_control" 2>/dev/null || true
}

case "$CGROUP_TYPE" in
  v1) setup_v1 ;;
  v2) setup_v2 ;;
esac

exec "$@"
