systemd_dir="/etc/systemd/system"

{% if use_system_level_systemd == 'False' %}
    systemd_dir="{{yb_user_home}}/.config/systemd/user"
    uid=$(id -u {{ yb_user }})
    user_run_dir="/run/user/$uid"
    test_dir="$user_run_dir/test_$$"
    created_user_run_dir=false

    # Check if /run/user/<uid> exists
    if [ ! -d "$user_run_dir" ]; then
        echo "$user_run_dir does not exist. Attempting to create it..."
        if mkdir -p "$user_run_dir" 2>/dev/null; then
            echo "Successfully created $user_run_dir."
            add_result "User Systemd Directory Check" "PASS" \
                "$user_run_dir was missing but created successfully."
            created_user_run_dir=true
        else
            echo "Failed to create $user_run_dir."
            add_result "User Systemd Directory Check" "FAIL" "Could not create $user_run_dir."
        fi
    else
        echo "$user_run_dir exists."
        add_result "User Systemd Directory Check" "PASS" "$user_run_dir already exists."
    fi

    # Clean up if we created /run/user/<uid>
    if [ "$created_user_run_dir" = true ]; then
        rm -rf "$user_run_dir" 2>/dev/null
        echo "Cleaned up $user_run_dir."
    fi
{% endif %}

{% if configure_cgroup == 'True' %}
YB_USER_HOME="{{ yb_user_home }}"
YB_USER="{{ yb_user }}"
CGROUP_TYPE_FILE="${YB_USER_HOME}/.yugabyte/cgroup_type"
CGROUP_V1_CPU_FILE="${YB_USER_HOME}/.yugabyte/cgroup_v1_cpu"
{% raw %}
if [ -f "$CGROUP_TYPE_FILE" ]; then
    cg_type=$(tr -d '\r\n' < "$CGROUP_TYPE_FILE")
    if [ "$cg_type" = "v1" ]; then
        # Verify the boot oneshot unit is installed and enabled.
        V1_BOOT_UNIT="yb-cgroup-v1-setup.service"
        if ! systemctl is-enabled "$V1_BOOT_UNIT" >/dev/null 2>&1; then
            add_result "Cgroup v1 boot oneshot" "FAIL" \
                "$V1_BOOT_UNIT is not enabled"
        else
            add_result "Cgroup v1 boot oneshot" "PASS" \
                "$V1_BOOT_UNIT is enabled"
        fi

        if [ -f "$CGROUP_V1_CPU_FILE" ]; then
            v1_cpu=$(tr -d '\r\n' < "$CGROUP_V1_CPU_FILE")
            if [ -n "$v1_cpu" ] && [ -d "$v1_cpu" ]; then
                leaf="${v1_cpu}/yugabyte-db"
                if [ ! -d "$leaf" ]; then
                    add_result "Cgroup v1 leaf directory" "FAIL" \
                        "$leaf does not exist; $V1_BOOT_UNIT may not have run"
                else
                    if [ "$(id -u)" -eq 0 ]; then
                        writable=$(su -s /bin/sh "$YB_USER" -c "test -w '$leaf'" 2>/dev/null && echo yes || echo no)
                    else
                        writable=$(test -w "$leaf" && echo yes || echo no)
                    fi
                    if [ "$writable" = "yes" ]; then
                        add_result "Cgroup v1 leaf directory" "PASS" \
                            "$leaf exists and is writable by $YB_USER"
                    else
                        add_result "Cgroup v1 leaf directory" "FAIL" \
                            "$leaf is not writable by $YB_USER"
                    fi
                fi
            fi
        fi
    fi
fi
{% endraw %}
{% endif %}

{% for service_file in service_files | split_string %}
    if [ ! -f "$systemd_dir"/{{ service_file }} ]; then
        echo "Systemd unit {{ service_file }} is not configured."
        add_result "Systemd Unit File Check - {{ service_file }}" "FAIL" \
            "Systemd unit {{ service_file }} is not configured."
    else
        echo "Systemd unit {{ service_file }} is configured."
        add_result "Systemd Unit File Check - {{ service_file }}" \
            "PASS" "Systemd unit {{ service_file }} is configured."
    fi
{% endfor %}
