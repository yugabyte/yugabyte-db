# Set default system level systemd
systemd_dir="/etc/systemd/system"

check_root_systemd_services() {
    local unit_paths=()
    local service_files=()
    {% if is_install_node_agent == 'True' %}
    service_files+=("yb-node-agent.service")
    {% endif %}
    {% if use_system_level_systemd == 'False' %}
    {% for service_file in service_files | split_string %}
    service_files+=("{{ service_file }}")
    {% endfor %}
    {% endif %}
    # Collect all the root systemd services first.
    {% raw %}
    for service_file in "${service_files[@]}"; do
      # Output is like /etc/systemd/system/yb-master.service.
      unit_path=$(systemctl cat $service_file  --no-pager 2>/dev/null | head -1 | sed -e 's/#\s*//g' || true)
      if [ -n "$unit_path" ] && [ -f "$unit_path" ]; then
        unit_paths+=("$unit_path")
      fi
    done
    if [ ${#unit_paths[@]} -gt 0 ]; then
        echo "Systemd root services ${unit_paths[*]} are already installed. Run with root provisioning to migrate to user-level systemd"
        exit 1
    fi
    {% endraw %}
}

{% if use_system_level_systemd == 'False' %}
    systemd_dir="{{ yb_user_home }}/.config/systemd/user"
    check_root_systemd_services
    if [ "$SUDO_ACCESS" = "true" ]; then
        su - {{ yb_user }} -c "mkdir -p ${systemd_dir}"
    else
        mkdir -p "${systemd_dir}"
    fi
# Configure the systemd unit files
{% for service_file in service_files | split_string %}
    tmp_file=$(mktemp)
    echo '{% include service_file %}' > "$tmp_file"
    if [ "$SUDO_ACCESS" = "true" ]; then
        chown {{ yb_user }}:{{ yb_user }} "$tmp_file"
        su - {{ yb_user }} -c "mv $tmp_file ${systemd_dir}/{{ service_file }}"
        su - {{ yb_user }} -c "chmod 644 ${systemd_dir}/{{ service_file }}"
    else
        mv "$tmp_file" "${systemd_dir}/{{ service_file }}"
        chmod 644 "${systemd_dir}/{{ service_file }}"
    fi
{% endfor %}
{% endif %}

{% if configure_cgroup == 'True' %}
# Root-only: v1 boot oneshot (yb-cgroup-v1-setup.service) or v2 user@ template drop-in (Delegate=pids memory cpu).
YB_USER_HOME="{{ yb_user_home }}"
YB_USER="{{ yb_user }}"
USE_SYS="{{ use_system_level_systemd }}"
CGROUP_TYPE=unknown
[ -f "$YB_USER_HOME/.yugabyte/cgroup_type" ] && CGROUP_TYPE=$(tr -d '\r\n' < "$YB_USER_HOME/.yugabyte/cgroup_type")
YB_UID=$(id -u "$YB_USER" 2>/dev/null || echo "")
V1_BOOT_UNIT=/etc/systemd/system/yb-cgroup-v1-setup.service
USER_AT_DROPIN_DIR=/etc/systemd/system/user@.service.d
USER_AT_DROPIN=$USER_AT_DROPIN_DIR/override.conf

if [ "$SUDO_ACCESS" = "true" ]; then
  if [ "$CGROUP_TYPE" = "v1" ]; then
    install -d "$(dirname "$V1_BOOT_UNIT")"
    cat >"$V1_BOOT_UNIT" <<'UNIT'
{% include 'yb-cgroup-v1-setup.service' %}
UNIT
    chmod 0644 "$V1_BOOT_UNIT"
    systemctl enable yb-cgroup-v1-setup.service 2>/dev/null || true
    systemctl start yb-cgroup-v1-setup.service 2>/dev/null || true
  else
    systemctl stop yb-cgroup-v1-setup.service 2>/dev/null || true
    systemctl disable yb-cgroup-v1-setup.service 2>/dev/null || true
    rm -f "$V1_BOOT_UNIT"
  fi

  if [ "$CGROUP_TYPE" = "v2" ] && [ "$USE_SYS" != "True" ]; then
    install -d -m 0755 "$USER_AT_DROPIN_DIR"
    printf '%s\n' '[Service]' 'Delegate=pids memory cpu' >"$USER_AT_DROPIN"
    chmod 0644 "$USER_AT_DROPIN"
  else
    rm -f "$USER_AT_DROPIN"
    rmdir "$USER_AT_DROPIN_DIR" 2>/dev/null || true
  fi
  systemctl daemon-reload || true
  if [ "$CGROUP_TYPE" = "v2" ] && [ "$USE_SYS" != "True" ] && [ -n "$YB_UID" ]; then
    systemctl stop "user@${YB_UID}.service" 2>/dev/null || true
    systemctl reset-failed "user@${YB_UID}.service" 2>/dev/null || true
    systemctl start "user@${YB_UID}.service" 2>/dev/null || true
  fi
elif [ "$CGROUP_TYPE" = "v2" ] && [ "$USE_SYS" != "True" ]; then
  echo "WARN: need root to install $USER_AT_DROPIN (cgroup v2, user systemd)"
fi

if [ "$USE_SYS" != "True" ] && [ -n "$YB_UID" ]; then
  if [ "$SUDO_ACCESS" = "true" ]; then
    su - "$YB_USER" -c "XDG_RUNTIME_DIR=/run/user/${YB_UID} systemctl --user daemon-reload" || true
  else
    XDG_RUNTIME_DIR="/run/user/${YB_UID}" systemctl --user daemon-reload || true
  fi
fi
{% endif %}
