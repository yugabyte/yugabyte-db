-- $map 'as' variable specified explicitly
SELECT document FROM bson_aggregation_pipeline(
  'db',
  '{
    "aggregate": "courses",
    "pipeline": [
      {
        "$lookup": {
          "from": "sharedFieldCatalog",
          "let": {
            "sharedFieldIds": {
              "$map": {
                "input": { "$ifNull": ["$SharedFieldRefs", []] },
                "as": "fieldRef",
                "in": "$$fieldRef._id"
              }
            }
          },
          "pipeline": [
            {
              "$match": {
                "$expr": {
                  "$and": [
                    { "$in": ["$_id", "$$sharedFieldIds"] },
                    { "$eq": ["$IsActive", true] }
                  ]
                }
              }
            }
          ],
          "as": "SharedFields"
        }
      }
    ]
  }'
);
