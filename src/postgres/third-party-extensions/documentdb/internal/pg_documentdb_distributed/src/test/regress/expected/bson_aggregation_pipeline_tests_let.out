SELECT document FROM bson_aggregation_pipeline('db', '
{
  "aggregate": "users3",
  "pipeline": [
    {
      "$lookup": {
        "from": "tags3",
        "let": {
          "flattenedTags": {
            "$reduce": {
              "input": "$groups",
              "initialValue": [],
              "in": {
                "$reduce": {
                  "input": "$$this.tags",
                  "initialValue": "$$value",
                  "in": { "$concatArrays": ["$$value", ["$$this"]] }
                }
              }
            }
          }
        },
        "pipeline": [
          {
            "$match": {
              "$expr": {
                "$in": ["$label", "$$flattenedTags"]
              }
            }
          }
        ],
        "as": "matchedTags"
      }
    },
    {
      "$project": {
        "_id": 0,
        "username": 1,
        "matchedTags": 1
      }
    }
  ]
}');
