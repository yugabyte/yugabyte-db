SELECT document FROM bson_aggregation_pipeline('db', '{
  "aggregate": "courses",
  "pipeline": [
    {
      "$lookup": {
        "from": "TopicCatalog",
        "let": {
          "transformedTopics": {
            "$map": {
              "input": "$topicRefs",
              "as": "topic",
              "in": [
                "$$topic",
                {
                  "$map": {
                    "input": "$$topic.tags",
                    "as": "tag",
                    "in": { "$toUpper": "$$tag" }
                  }
                }
              ]
            }
          }
        },
        "pipeline": [
          {
            "$match": {
              "$expr": {
                "$in": [
                  "$_id",
                  {
                    "$map": {
                      "input": "$$transformedTopics",
                      "as": "t",
                      "in": { "$arrayElemAt": ["$$t", 0] }
                    }
                  }
                ]
              }
            }
          },
          {
            "$project": {
              "_id": 1,
              "name": 1
            }
          }
        ],
        "as": "topics"
      }
    },
    {
      "$project": {
        "_id": 1,
        "name": 1,
        "topics": 1,
        "transformedTags": 1
      }
    }
  ]
}');
