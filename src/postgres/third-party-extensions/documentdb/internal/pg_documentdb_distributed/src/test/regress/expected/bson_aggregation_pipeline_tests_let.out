-- $lookup with let with $reduce; access only $$this
SELECT document FROM bson_aggregation_pipeline('db', '
{
  "aggregate": "users2",
  "pipeline": [
    {
      "$lookup": {
        "from": "tags2",
        "let": {
          "allTags": {
            "$reduce": {
              "input": "$groups",
              "initialValue": [],
              "in": "$$this.tags"
            }
          }
        },
        "pipeline": [
          {
            "$match": {
              "$expr": {
                "$in": ["$label", "$$allTags"]
              }
            }
          }
        ],
        "as": "matchedTags"
      }
    },
    {
      "$project": {
        "_id": 0,
        "username": 1,
        "matchedTags": 1
      }
    }
  ]
}');
