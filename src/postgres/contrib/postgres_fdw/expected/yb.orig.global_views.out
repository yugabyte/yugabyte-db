         Remote SQL: SELECT node_id, metric_name, event_count FROM public.local_node_metrics WHERE ((abs(event_count) > 100)) ORDER BY node_id ASC NULLS LAST, metric_name ASC NULLS LAST
   ->  Foreign Scan on public."gv$node_metrics" "gv$node_metrics_3"
         Output: "gv$node_metrics_3".node_id, "gv$node_metrics_3".metric_name, "gv$node_metrics_3".event_count
