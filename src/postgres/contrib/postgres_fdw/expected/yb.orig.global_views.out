         Filter: ("gv$node_metrics_1".updated_at < now())
         Remote SQL: SELECT node_id, metric_name, updated_at FROM public.local_node_metrics ORDER BY node_id ASC NULLS LAST, metric_name ASC NULLS LAST
   ->  Foreign Scan on public."gv$node_metrics" "gv$node_metrics_2"
         Output: "gv$node_metrics_2".node_id, "gv$node_metrics_2".metric_name, "gv$node_metrics_2".updated_at
         Filter: ("gv$node_metrics_2".updated_at < now())
         Remote SQL: SELECT node_id, metric_name, updated_at FROM public.local_node_metrics ORDER BY node_id ASC NULLS LAST, metric_name ASC NULLS LAST
   ->  Foreign Scan on public."gv$node_metrics" "gv$node_metrics_3"
         Output: "gv$node_metrics_3".node_id, "gv$node_metrics_3".metric_name, "gv$node_metrics_3".updated_at
         Filter: ("gv$node_metrics_3".updated_at < now())
         Remote SQL: SELECT node_id, metric_name, updated_at FROM public.local_node_metrics ORDER BY node_id ASC NULLS LAST, metric_name ASC NULLS LAST
