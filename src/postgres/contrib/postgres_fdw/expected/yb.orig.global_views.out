EXPLAIN (VERBOSE, COSTS OFF)
SELECT metric_name,
       COUNT(*) AS node_count,
       SUM(event_count) AS total_events,
       SUM(total_bytes) AS total_bytes_sum
FROM "gv$node_metrics"
GROUP BY metric_name
ORDER BY metric_name;
                                                                 QUERY PLAN                                                                 
--------------------------------------------------------------------------------------------------------------------------------------------
 Sort
   Output: metric_name, (count(*)), (sum(event_count)), (sum(total_bytes))
   Sort Key: "gv$node_metrics".metric_name
   ->  HashAggregate
         Output: metric_name, count(*), sum(event_count), sum(total_bytes)
         Group Key: "gv$node_metrics".metric_name
         ->  Foreign Scan on public."gv$node_metrics"
               Output: node_id, metric_name, metric_value, event_count, total_bytes, ratio, is_healthy, tag, status, created_at, updated_at
               Remote SQL: SELECT metric_name, event_count, total_bytes FROM public.local_node_metrics
(9 rows)

