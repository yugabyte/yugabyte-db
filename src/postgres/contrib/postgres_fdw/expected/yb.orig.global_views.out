               Remote Filter: ("gv$node_metrics_2".node_id = 1)
               Remote SQL: SELECT metric_name FROM public.local_node_metrics WHERE ((node_id = 1))
         ->  Foreign Scan on public."gv$node_metrics" "gv$node_metrics_3"
