--
-- Rescan correctness: Nested Loop is forced by disabling competing
-- join strategies, so postgresReScanForeignScan is exercised.
--
CREATE TABLE gv_driver_nodes (node_id int, label text);
INSERT INTO gv_driver_nodes VALUES (1, 'first'), (3, 'third');
SET enable_hashjoin = off;
SET enable_mergejoin = off;
SET enable_material = off;
EXPLAIN (VERBOSE, COSTS OFF)
SELECT d.label, gv.metric_name, gv.event_count
FROM gv_driver_nodes d, "gv$node_metrics" gv
WHERE gv.node_id = d.node_id
ORDER BY d.label, gv.metric_name;
                                               QUERY PLAN                                                
---------------------------------------------------------------------------------------------------------
 Sort
   Output: d.label, gv.metric_name, gv.event_count
   Sort Key: d.label, gv.metric_name
   ->  Nested Loop
         Output: d.label, gv.metric_name, gv.event_count
         Join Filter: (d.node_id = gv.node_id)
         ->  Append
               ->  Foreign Scan on public."gv$node_metrics" gv_1
                     Output: gv_1.metric_name, gv_1.event_count, gv_1.node_id
                     Remote SQL: SELECT node_id, metric_name, event_count FROM public.local_node_metrics
               ->  Foreign Scan on public."gv$node_metrics" gv_2
                     Output: gv_2.metric_name, gv_2.event_count, gv_2.node_id
                     Remote SQL: SELECT node_id, metric_name, event_count FROM public.local_node_metrics
               ->  Foreign Scan on public."gv$node_metrics" gv_3
                     Output: gv_3.metric_name, gv_3.event_count, gv_3.node_id
                     Remote SQL: SELECT node_id, metric_name, event_count FROM public.local_node_metrics
         ->  Seq Scan on public.gv_driver_nodes d
               Output: d.label, d.node_id
(18 rows)

SELECT d.label, gv.metric_name, gv.event_count
FROM gv_driver_nodes d, "gv$node_metrics" gv
WHERE gv.node_id = d.node_id
ORDER BY d.label, gv.metric_name;
 label | metric_name  | event_count 
-------+--------------+-------------
 first |              |          77
 first | cpu_usage    |         100
 first | disk_io      |          50
 first | memory_usage |         200
 third | cpu_usage    |          90
 third | disk_io      |          60
 third | memory_usage |         250
(7 rows)

RESET enable_material;
RESET enable_hashjoin;
RESET enable_mergejoin;
DROP TABLE gv_driver_nodes;
--
-- Non-decomposable aggregates must NOT be pushed down as partial
-- aggregates to individual tservers. Verify the aggregate runs locally.
--
EXPLAIN (VERBOSE, COSTS OFF)
SELECT string_agg(metric_name, ', ' ORDER BY metric_name)
FROM "gv$node_metrics"
WHERE node_id = 1;
                                                       QUERY PLAN                                                       
------------------------------------------------------------------------------------------------------------------------
 Aggregate
   Output: string_agg(("gv$node_metrics".metric_name)::text, ', '::text ORDER BY ("gv$node_metrics".metric_name)::text)
   ->  Append
         ->  Foreign Scan on public."gv$node_metrics" "gv$node_metrics_1"
               Output: "gv$node_metrics_1".metric_name
