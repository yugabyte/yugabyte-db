-- ASH with current_timestamp (stable, not pushed down)
EXPLAIN (VERBOSE, COSTS OFF)
SELECT
    query_id,
    wait_event_component,
    wait_event,
    wait_event_type,
    COUNT(*)
FROM
    "gv$yb_active_session_history"
WHERE
    sample_time >= current_timestamp - interval '20 minutes'
GROUP BY
    query_id,
    wait_event_component,
    wait_event,
    wait_event_type
ORDER BY
    query_id,
    wait_event_component,
    wait_event_type
LIMIT 10;
