{ name => 'yb_test_stay_in_global_catalog_version_mode', type => 'bool', context => 'PGC_SUSET', group => 'DEVELOPER_OPTIONS',
  short_desc => 'When set, this PG backend will stay in global catalog version mode. Used in testing to simulate a lagging PG backend during the finalization phase of cluster upgrade to a new release that has the per-database catalog version mode on by default.',
  flags => 'GUC_NOT_IN_SAMPLE',
  variable => 'yb_test_stay_in_global_catalog_version_mode',
