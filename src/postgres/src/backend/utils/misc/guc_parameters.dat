},

{ name => 'yb_insert_on_conflict_read_batch_size', type => 'int', context => 'PGC_SUSET', group => 'CLIENT_CONN_STATEMENT',
  short_desc => 'Maximum batch size for arbiter index reads during INSERT ON CONFLICT.',
