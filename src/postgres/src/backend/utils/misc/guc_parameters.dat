},

{ name => 'yb_test_ybgin_disable_cost_factor', type => 'real', context => 'PGC_USERSET', group => 'QUERY_TUNING_COST',
  short_desc => 'The multiplier to disable_cost to add when costing ybgin index scans that may not be supported.',
  flags => 'GUC_NOT_IN_SAMPLE',
  variable => 'yb_test_ybgin_disable_cost_factor',
  boot_val => '2.0',
  min => '0.0',
  max => '10.0',
},

{ name => 'yb_toast_catcache_threshold', type => 'int', context => 'PGC_USERSET', group => 'CUSTOM_OPTIONS',
