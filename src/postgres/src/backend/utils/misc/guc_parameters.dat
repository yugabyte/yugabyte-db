{ name => 'yb_query_diagnostics_disable_database_connection_bgworker', type => 'bool', context => 'PGC_SIGHUP', group => 'STATS_MONITORING',
  short_desc => 'This disables creating extra bgworker which creates database connection for query diagnostics. If this is set to true, ASH and schema details are not dumped',
  flags => 'GUC_NOT_IN_SAMPLE',
  variable => 'yb_query_diagnostics_disable_database_connection_bgworker',
  boot_val => 'false',
},

{ name => 'yb_read_after_commit_visibility', type => 'enum', context => 'PGC_USERSET', group => 'CUSTOM_OPTIONS',
  short_desc => 'Control read-after-commit-visibility guarantee.',
  long_desc => 'This GUC is intended as a crutch for users migrating from PostgreSQL and new to read restart errors. Users can now largely avoid these errors when read-after-commit-visibility guarantee is not a strong requirement. This option cannot be set from within a transaction block. Configure one of the following options: (a) strict: Default Behavior. The read-after-commit-visibility guarantee is maintained by the database. However, users may see read restart errors that show "ERROR:  Query error: Restart read required at: ...". The database attempts to retry on such errors internally but that is not always possible. (b) relaxed: With this option, the read-after-commit-visibility guarantee is relaxed. Do not see read restart errors but may miss recent updates with staleness bounded by clock skew. This mode does not apply to serializable isolation level and fast path writes. (c) deferred: Defers read point. Higher latency but read-after-commit-visibility guarantee is maintained.',
  variable => 'yb_read_after_commit_visibility',
  boot_val => 'YB_STRICT_READ_AFTER_COMMIT_VISIBILITY',
  options => 'yb_read_after_commit_visibility_options',
  check_hook => 'yb_check_no_txn',
},

{ name => 'yb_read_from_followers', type => 'bool', context => 'PGC_USERSET', group => 'CLIENT_CONN_STATEMENT',
  short_desc => 'Allow any statement that generates a read request to go to any node.',
  flags => 'GUC_NOT_IN_SAMPLE',
  variable => 'yb_read_from_followers',
  boot_val => 'false',
  check_hook => 'check_follower_reads',
  assign_hook => 'assign_follower_reads',
},

{ name => 'yb_read_time', type => 'string', context => 'PGC_SUSET', group => 'CLIENT_CONN_STATEMENT',
  short_desc => 'Allows querying the database as of a point in time in the past. Takes a unix timestamp in microseconds. Zero means reading data as of current time.',
  long_desc => 'User should set this variable with caution. Currently, it can only read old data without schema changes. In other words, it should not be set to a timestamp before a DDL operation has been performed. Write-DML or DDL queries are not allowed while this variable is set.',
  variable => 'yb_read_time_string',
  boot_val => '"0"',
  check_hook => 'check_yb_read_time',
  assign_hook => 'assign_yb_read_time',
},

{ name => 'yb_refresh_matview_in_place', type => 'bool', context => 'PGC_USERSET', group => 'CUSTOM_OPTIONS',
  short_desc => 'Refresh materialized views in place.',
  flags => 'GUC_NOT_IN_SAMPLE',
  variable => 'yb_refresh_matview_in_place',
  boot_val => 'false',
},

{ name => 'yb_reorderbuffer_max_changes_in_memory', type => 'int', context => 'PGC_USERSET', group => 'DEVELOPER_OPTIONS',
  short_desc => 'Maximum number of changes kept in memory per transaction in reorder buffer, which is used in streaming changes via logical replication. After that, changes are spooled to disk.',
  flags => 'GUC_NOT_IN_SAMPLE',
  variable => 'yb_reorderbuffer_max_changes_in_memory',
  boot_val => '4096',
  min => '0',
  max => 'INT_MAX',
},

{ name => 'yb_sampling_algorithm', type => 'enum', context => 'PGC_USERSET', group => 'QUERY_TUNING_OTHER',
  short_desc => 'Which sampling algorithm to use for YSQL. full_table_scan - scan the whole table and pick random rows, block_based_sampling - sample the table for a set of blocks, then scan selected blocks to form a final rows sample.',
  variable => 'yb_sampling_algorithm',
  boot_val => 'YB_SAMPLING_ALGORITHM_BLOCK_BASED_SAMPLING',
  options => 'yb_sampling_algorithm_options',
},

{ name => 'yb_silence_advisory_locks_not_supported_error', type => 'bool', context => 'PGC_USERSET', group => 'LOCK_MANAGEMENT',
  short_desc => 'Silence the advisory locks error message.',
  long_desc => 'Enable this with high caution. When enabled, advisory lock requests will silently succeed without actually executing the lock request. It was added to avoid disruption for users who were already using advisory locks but seeing success messages without the lock really being acquired. Such users should take the necessary steps to modify their application to remove usage of advisory locks. See https://github.com/yugabyte/yugabyte-db/issues/3642 for details.',
  flags => 'GUC_NOT_IN_SAMPLE',
  variable => 'yb_silence_advisory_locks_not_supported_error',
  boot_val => 'false',
  assign_hook => 'assign_yb_silence_advisory_locks_not_supported_error',
},

{ name => 'yb_skip_ensure_read_time_in_parallel_execution', type => 'bool', context => 'PGC_USERSET', group => 'DEVELOPER_OPTIONS',
  short_desc => 'Skip forcing ENSURE_READ_TIME_IS_SET during parallel execution.',
  long_desc => 'When true, parallel execution will not force read time to be picked on the proxy. This should be used with caution.',
  flags => 'GUC_NOT_IN_SAMPLE | GUC_NO_SHOW_ALL',
  variable => 'yb_skip_ensure_read_time_in_parallel_execution',
  boot_val => 'false',
},

{ name => 'yb_skip_redundant_update_ops', type => 'bool', context => 'PGC_SIGHUP', group => 'QUERY_TUNING_OTHER',
  short_desc => 'Enables the comparison of old and new values of columns specified in the SET clause of YSQL UPDATE queries to skip redundant secondary index updates and redundant constraint checks.',
  flags => 'GUC_NOT_IN_SAMPLE',
  variable => 'yb_update_optimization_options.is_enabled',
  boot_val => 'true',
},

{ name => 'yb_speculatively_execute_pl_statements', type => 'bool', context => 'PGC_SUSET', group => 'CUSTOM_OPTIONS',
  short_desc => 'If enabled, procedural language statements may be speculatively executed when it is safe to do so without waiting for the successful completion of previous statements. This allows any writes produced by triggers to be batched alongside their parent data-modifying writes such that the number of storages flushes may be minimized.',
  flags => 'GUC_NOT_IN_SAMPLE',
  variable => 'yb_speculatively_execute_pl_statements',
  boot_val => 'false',
},

{ name => 'yb_tcmalloc_sample_period', type => 'int', context => 'PGC_SUSET', group => 'STATS_MONITORING',
  short_desc => 'TCMalloc sample interval in bytes, i.e. approximately how many bytes between sampling allocation call stacks',
  flags => 'GUC_UNIT_BYTE',
  variable => 'yb_tcmalloc_sample_period',
  boot_val => '1024 * 1024',
  min => '0',
  max => 'INT_MAX',
  assign_hook => 'assign_tcmalloc_sample_period',
  show_hook => 'show_tcmalloc_sample_period',
},

