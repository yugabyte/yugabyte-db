  short_desc => 'Relaxes some internal sanity checks for system catalogs to allow creating them.',
  flags => 'GUC_NOT_IN_SAMPLE',
  variable => 'yb_test_system_catalogs_creation',
  boot_val => 'false',
},

{ name => 'yb_test_table_rewrite_keep_old_table', type => 'bool', context => 'PGC_SUSET', group => 'DEVELOPER_OPTIONS',
  short_desc => 'When set, DDLs that rewrite tables/indexes will not drop the old relfilenode/DocDB table.',
  flags => 'GUC_NOT_IN_SAMPLE',
  variable => 'yb_test_table_rewrite_keep_old_table',
