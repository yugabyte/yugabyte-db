{ name => 'yb_enable_retry_after_non_atomic_commit', type => 'bool', context => 'PGC_USERSET', group => 'COMPAT_OPTIONS_PREVIOUS',
  short_desc => 'Allow query layer retries of CALL/DO statements after an in-procedure COMMIT.',
  long_desc => 'When enabled, the query layer will retry CALL and DO statements on conflict or read-restart errors even if the procedure or DO block has already performed a COMMIT. This can lead to re-execution of already-committed work (e.g., duplicate inserts) and is provided only as a compatibility option to revert to the old behavior. The default (off) is the safe behavior.',
  variable => 'yb_enable_retry_after_non_atomic_commit',
  boot_val => 'false',
},

{ name => 'yb_enable_saop_pushdown', type => 'bool', context => 'PGC_USERSET', group => 'QUERY_TUNING_METHOD',
  short_desc => 'Push supported scalar array operations down to DocDB for evaluation.',
  variable => 'yb_enable_saop_pushdown',
  boot_val => 'true',
},

{ name => 'yb_enable_sequence_pushdown', type => 'bool', context => 'PGC_USERSET', group => 'QUERY_TUNING_METHOD',
  short_desc => 'Allow nextval() to fetch the value range and advance the sequence value in a single operation.',
  variable => 'yb_enable_sequence_pushdown',
  boot_val => 'true',
},

{ name => 'yb_enable_update_reltuples_after_create_index', type => 'bool', context => 'PGC_USERSET', group => 'QUERY_TUNING_OTHER',
  short_desc => 'Enables update of reltuples in pg_class for the base table and index after creating the index. When disabled, reltuples are not updated during concurrent index creation and only index reltuples are updated during non-concurrent index creation.',
  flags => 'GUC_EXPLAIN',
  variable => 'yb_enable_update_reltuples_after_create_index',
  boot_val => 'false',
},

{ name => 'yb_enable_upsert_mode', type => 'bool', context => 'PGC_USERSET', group => 'CLIENT_CONN_STATEMENT',
  short_desc => 'Sets the boolean flag to enable or disable upsert mode for writes.',
  variable => 'yb_enable_upsert_mode',
  boot_val => 'false',
},

{ name => 'yb_explain_hide_non_deterministic_fields', type => 'bool', context => 'PGC_USERSET', group => 'CUSTOM_OPTIONS',
  short_desc => 'If set, all fields that vary from run to run are hidden from the output of EXPLAIN.',
  flags => 'GUC_NOT_IN_SAMPLE',
  variable => 'yb_explain_hide_non_deterministic_fields',
  boot_val => 'false',
},

{ name => 'yb_explicit_row_locking_batch_size', type => 'int', context => 'PGC_USERSET', group => 'QUERY_TUNING_OTHER',
  short_desc => 'Batch size of explicit row locking',
  long_desc => 'Set to 1 to conserve default behavior, batching is disabled by default.',
