},

{ name => 'yb_log_heap_snapshot_on_exit_threshold', type => 'int', context => 'PGC_USERSET', group => 'DEVELOPER_OPTIONS',
  short_desc => 'When a process exits, log a peak heap snapshot showing the approximate memory usage of each malloc call stack if its peak RSS is greater than or equal to this threshold in KB. Set to -1 to disable.',
  flags => 'GUC_UNIT_KB | GUC_NOT_IN_SAMPLE',
  variable => 'yb_log_heap_snapshot_on_exit_threshold',
  boot_val => '-1',
  min => '-1',
  max => 'INT_MAX',
},

{ name => 'yb_log_min_backtraces', type => 'enum', context => 'PGC_SUSET', group => 'LOGGING_WHEN',
  short_desc => 'Sets the minimum message level for including a backtrace in the log.',
