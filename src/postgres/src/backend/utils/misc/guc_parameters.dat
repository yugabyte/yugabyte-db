{ name => 'yb_test_skip_binding_scan_keys', type => 'bool', context => 'PGC_USERSET', group => 'DEVELOPER_OPTIONS',
  short_desc => 'For YB scans, skip binding scan keys to pggate. ybgin and internal scans are not affected.',
  flags => 'GUC_NOT_IN_SAMPLE | GUC_EXPLAIN',
