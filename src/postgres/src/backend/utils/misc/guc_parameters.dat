},

{ name => 'yb_test_slowdown_index_check', type => 'bool', context => 'PGC_SUSET', group => 'DEVELOPER_OPTIONS',
  short_desc => 'Slows down yb_index_check() by sleeping for 1s after processing every row. Used in tests to simulate long running yb_index_check().',
  flags => 'GUC_NOT_IN_SAMPLE',
