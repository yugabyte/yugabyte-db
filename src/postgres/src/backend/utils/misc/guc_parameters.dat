  short_desc => 'When set, all DDL statements will cause the catalog version to increment. This mainly affects CREATE commands such as CREATE TABLE, CREATE VIEW, and CREATE SEQUENCE. This also enables negative catcache entries.',
  variable => 'yb_test_make_all_ddl_statements_incrementing',
  boot_val => 'true',
},

{ name => 'yb_test_planner_custom_plan_threshold', type => 'int', context => 'PGC_USERSET', group => 'DEVELOPER_OPTIONS',
  short_desc => 'The number of times to force custom plan generation for prepared statements before considering a generic plan.',
  variable => 'yb_test_planner_custom_plan_threshold',
