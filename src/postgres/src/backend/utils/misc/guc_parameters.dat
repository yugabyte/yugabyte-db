  options => 'server_message_level_options',
},

{ name => 'yb_major_version_upgrade_compatibility', type => 'int', context => 'PGC_SIGHUP', group => 'CUSTOM_OPTIONS',
  short_desc => 'The compatibility level to use during a YSQL Major version upgrade. Allowed values are 0 and 11.',
  flags => 'GUC_NOT_IN_SAMPLE',
  variable => 'yb_major_version_upgrade_compatibility',
  boot_val => '0',
  min => '0',
  max => 'INT_MAX',
},

{ name => 'yb_make_next_ddl_statement_nonbreaking', type => 'bool', context => 'PGC_SUSET', group => 'CUSTOM_OPTIONS',
  short_desc => 'When set, the next ddl statement will not cause running transactions to abort. This only affects the next ddl statement and resets automatically.',
  variable => 'yb_make_next_ddl_statement_nonbreaking',
  boot_val => 'false',
},

{ name => 'yb_make_next_ddl_statement_nonincrementing', type => 'bool', context => 'PGC_SUSET', group => 'CUSTOM_OPTIONS',
  short_desc => 'DEPRECATED - When set, the next ddl statement will not cause catalog version to increment. This only affects the next ddl statement and resets automatically.',
  variable => 'yb_make_next_ddl_statement_nonincrementing',
  boot_val => 'false',
},

{ name => 'yb_max_merge_scan_streams', type => 'int', context => 'PGC_USERSET', group => 'QUERY_TUNING_METHOD',
  short_desc => 'Sets the maximum number of streams tolerated for merge scan.',
  long_desc => 'For YB LSM index scans, when multiple merge-scan-eligible scalar array operations are involved, they are combined until their cartesian product\'s cardinality reaches this limit. Merge scan is per index scan, and the limit applies per index scan, not globally. Set to 0 to disable.',
  variable => 'yb_max_merge_scan_streams',
  boot_val => '0',
  min => '0',
  max => '1024',
},

{ name => 'yb_max_num_invalidation_messages', type => 'int', context => 'PGC_SUSET', group => 'DEVELOPER_OPTIONS',
  short_desc => 'Max number of invalidation messages supported for incremental catalog cache refresh.',
  flags => 'GUC_NOT_IN_SAMPLE',
  variable => 'yb_max_num_invalidation_messages',
  boot_val => '4096',
  min => '0',
  max => 'INT_MAX',
},

{ name => 'yb_max_query_layer_retries', type => 'int', context => 'PGC_USERSET', group => 'CLIENT_CONN_STATEMENT',
  short_desc => 'Max number of internal query layer retries of a statement',
  long_desc => 'Max number of query layer retries of a statement for the following errors: serialization error (40001), "Restart read required" (40001), deadlock detected (40P01). In Repeatable Read and Serializable isolation levels, the query layer only retries errors faced in the first statement of a transation. In READ COMMITTED isolation, the query layer has the ability to do retries for any statement in a transaction. Retries are not possible if some response data has already been sent to the client while the query is still executing. This happens if the output buffer, the size of which is configurable using the TServer gflag ysql_output_buffer_size, has filled atleast once and is flushed.',
  variable => 'yb_max_query_layer_retries',
  boot_val => '60',
  min => '0',
  max => 'INT_MAX',
},

{ name => 'yb_mixed_mode_expression_pushdown', type => 'bool', context => 'PGC_USERSET', group => 'CUSTOM_OPTIONS',
  short_desc => 'Enables expression pushdown for queries in mixed mode of a YSQL Major version upgrade.',
  flags => 'GUC_NOT_IN_SAMPLE',
  variable => 'yb_mixed_mode_expression_pushdown',
  boot_val => 'true',
},

{ name => 'yb_mixed_mode_saop_pushdown', type => 'bool', context => 'PGC_USERSET', group => 'CUSTOM_OPTIONS',
  short_desc => 'Enable pushdown of scalar array operation expressions in mixed mode of a YSQL Major version upgrade. For example, IN, ANY, ALL.',
  flags => 'GUC_NOT_IN_SAMPLE',
  variable => 'yb_mixed_mode_saop_pushdown',
  boot_val => 'false',
},

