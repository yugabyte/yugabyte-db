},

{ name => 'yb_query_diagnostics_circular_buffer_size', type => 'int', context => 'PGC_POSTMASTER', group => 'STATS_MONITORING',
  short_desc => 'Size of query diagnostics circular buffer that stores statuses of bundles',
  long_desc => 'The circular buffer is filled sequentially until it reaches this size, then it wraps around and starts overwriting the oldest entries.',
  flags => 'GUC_UNIT_KB',
  variable => 'yb_query_diagnostics_circular_buffer_size',
