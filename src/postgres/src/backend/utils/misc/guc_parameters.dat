{ name => 'yb_update_max_cols_size_to_compare', type => 'int', context => 'PGC_USERSET', group => 'CUSTOM_OPTIONS',
  short_desc => 'Maximum size in bytes of columns whose data is to be compared while seeking to optimize updates. If set to 0, no size limit is applied.',
  flags => 'GUC_UNIT_BYTE',
  variable => 'yb_update_optimization_options.max_cols_size_to_compare',
  boot_val => '10 * 1024',
  min => '0',
  max => 'INT_MAX',
},

{ name => 'yb_update_num_cols_to_compare', type => 'int', context => 'PGC_USERSET', group => 'CUSTOM_OPTIONS',
  short_desc => 'Maximum number of columns whose data is to be compared while seeking to optimize updates. If set to 0, all applicable columns in the table will be compared.',
  variable => 'yb_update_optimization_options.num_cols_to_compare',
  boot_val => '50',
  min => '0',
  max => 'INT_MAX',
},

{ name => 'yb_update_optimization_infra', type => 'bool', context => 'PGC_SIGHUP', group => 'QUERY_TUNING_OTHER',
  short_desc => 'Enables optimizations of YSQL UPDATE queries. This includes (but not limited to) skipping redundant secondary index updates and redundant constraint checks.',
  flags => 'GUC_NOT_IN_SAMPLE',
  variable => 'yb_update_optimization_options.has_infra',
  boot_val => 'true',
},

{ name => 'yb_upgrade_to_pg15_completed', type => 'bool', context => 'PGC_SIGHUP', group => 'CUSTOM_OPTIONS',
  short_desc => 'Indicates the state of YSQL major upgrade to PostgreSQL version 15. Do not modify this manually.',
  flags => 'GUC_NOT_IN_SAMPLE',
  variable => 'yb_upgrade_to_pg15_completed',
  boot_val => 'true',
},

{ name => 'yb_use_cluster_config_for_geolocation_costing', type => 'bool', context => 'PGC_USERSET', group => 'QUERY_TUNING_METHOD',
  short_desc => 'When no tablespace is assigned to table, use cluster replication info to estimate network costs',
  flags => 'GUC_EXPLAIN',
  variable => 'yb_use_cluster_config_for_geolocation_costing',
  boot_val => 'false',
},

{ name => 'yb_use_hash_splitting_by_default', type => 'bool', context => 'PGC_USERSET', group => 'QUERY_TUNING_OTHER',
  short_desc => 'Enables hash splitting as the default method for primary key and index sorting in LSM indexes',
  long_desc => 'When set to true, the default sorting for the first primary/index key column in LSM indexes is HASH, Setting this to false changes the default to ASC, making it compatible with standard PostgreSQL behavior. This setting is useful for optimizing query performance, especially for migrations from PostgreSQL or scenarios where index-based sorting and sharding behavior are critical.',
  variable => 'yb_use_hash_splitting_by_default',
  boot_val => 'true',
},

{ name => 'yb_use_internal_auto_analyze_service_conn', type => 'bool', context => 'PGC_USERSET', group => 'VACUUM_AUTOVACUUM',
  short_desc => '[Internal Only GUC] - Help a backend identify that this is a connection from the internal Auto-Analyze service',
  flags => 'GUC_NOT_IN_SAMPLE',
  variable => 'yb_use_internal_auto_analyze_service_conn',
  boot_val => 'false',
},

{ name => 'yb_use_tserver_key_auth', type => 'bool', context => 'PGC_BACKEND', group => 'UNGROUPED',
  short_desc => 'If set, the client connection will be authenticated via \'yb-tserver-key\' auth',
  flags => 'GUC_NOT_IN_SAMPLE',
  variable => 'yb_use_tserver_key_auth',
  boot_val => 'false',
  check_hook => 'yb_use_tserver_key_auth_check_hook',
},

{ name => 'yb_user_ddls_preempt_auto_analyze', type => 'bool', context => 'PGC_USERSET', group => 'DEVELOPER_OPTIONS',
  short_desc => 'If object locking is off (i.e., enable_object_locking_for_table_locks=false), concurrent DDLs might face a conflict error on the catalog version increment at the end after doing all the work. Setting this flag enables a fail-fast strategy by locking the catalog version at the start of DDLs, causing conflict errors to occur before useful work is done. This flag is only applicable without object locking. If object locking is enabled, it ensures that concurrent DDLs block on each other for serialization. Also, this flag is valid only if ysql_enable_db_catalog_version_mode and yb_enable_invalidation_messages are enabled.',
  flags => 'GUC_NOT_IN_SAMPLE',
  variable => 'yb_user_ddls_preempt_auto_analyze',
  boot_val => 'true',
},

{ name => 'yb_wait_for_backends_catalog_version_timeout', type => 'int', context => 'PGC_USERSET', group => 'QUERY_TUNING_METHOD',
  short_desc => 'Timeout in milliseconds to wait for backends to reach desired catalog versions.',
  long_desc => 'The actual time spent may be longer than that by as much as master flag wait_for_ysql_backends_catalog_version_client_master_rpc_timeout_ms. Setting to zero or less results in no timeout. Currently used by concurrent CREATE INDEX.',
  flags => 'GUC_UNIT_MS',
  variable => 'yb_wait_for_backends_catalog_version_timeout',
  boot_val => '15 * 60 * 1000',
  min => '0',
  max => 'INT_MAX',
},

{ name => 'yb_walsender_poll_sleep_duration_empty_ms', type => 'int', context => 'PGC_USERSET', group => 'DEVELOPER_OPTIONS',
  short_desc => 'Time in milliseconds for which Walsender waits before fetching the next batch of changes from the CDC service in case the last received response was empty.',
  flags => 'GUC_UNIT_MS',
  variable => 'yb_walsender_poll_sleep_duration_empty_ms',
  boot_val => '10',
  min => '0',
