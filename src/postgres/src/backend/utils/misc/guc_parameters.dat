{ name => 'yb_follower_reads_behavior_before_fixing_20482', type => 'bool', context => 'PGC_USERSET', group => 'CLIENT_CONN_STATEMENT',
  short_desc => 'Controls whether ysql follower reads that is enabled inside a transaction block should take effect in the same transaction or not. Prior to fixing #20482 the behavior was that the change does not affect the current transaction but only affects subsequent transactions. The flag is intended to be used if there is a customer who relies on the old behavior.',
  flags => 'GUC_NOT_IN_SAMPLE',
  variable => 'yb_follower_reads_behavior_before_fixing_20482',
  boot_val => 'false',
},

{ name => 'yb_force_catalog_update_on_next_ddl', type => 'bool', context => 'PGC_USERSET', group => 'DEVELOPER_OPTIONS',
  short_desc => 'Make the next DDL update the catalog in force mode which allows it to operate even during ysql major catalog upgrades. WARNING: This is a dangerous option and should be used only for DDLs on temp tables, and other transient objects.',
  flags => 'GUC_NOT_IN_SAMPLE',
  variable => 'yb_force_catalog_update_on_next_ddl',
  boot_val => 'false',
},

{ name => 'yb_force_tablespace_locality', type => 'bool', context => 'PGC_USERSET', group => 'UNGROUPED',
