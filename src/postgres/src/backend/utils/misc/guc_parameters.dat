{ name => 'yb_ignore_read_time_in_walsender', type => 'bool', context => 'PGC_USERSET', group => 'CUSTOM_OPTIONS',
  short_desc => 'When set, walsender will fetch the publication as of current time if it encounters any failures while reading the catalog tables as of yb_read_time',
  long_desc => 'This GUC should be set carefully and only till the time the process of upgrading logical replication streams is complete (i.e till the yb_restart_time of all the streams crosses the time of upgrade completion). Moreover this GUC should be set only after ensuring that no more DDLs (including ALTER PUBLICATION) will be encountered by the walsender',
  flags => 'GUC_NOT_IN_SAMPLE',
  variable => 'yb_ignore_read_time_in_walsender',
  boot_val => 'false',
},

{ name => 'yb_ignore_relfilenode_ids', type => 'bool', context => 'PGC_SUSET', group => 'DEVELOPER_OPTIONS',
  short_desc => 'Ignores requests to set relfilenode IDs in yb_binary_restore mode',
  flags => 'GUC_NOT_IN_SAMPLE',
  variable => 'yb_ignore_relfilenode_ids',
  boot_val => 'true',
},

{ name => 'yb_index_state_flags_update_delay', type => 'int', context => 'PGC_USERSET', group => 'QUERY_TUNING_METHOD',
  short_desc => 'Delay in milliseconds between stages of online index build.',
  long_desc => 'Set high to give online transactions more time to complete.',
  flags => 'GUC_UNIT_MS',
  variable => 'yb_index_state_flags_update_delay',
  boot_val => '0',
  min => '0',
