  short_desc => 'Ignore boolean condition for row count estimate in legacy cost model.',
  long_desc => 'Negates the side effect on legacy mode row count estimate introduced by the fix "[#26266] YSQL: Add BOOL_LSM_FAM_OID to boolean family" for backward compatibility',
  flags => 'GUC_EXPLAIN',
  variable => 'yb_ignore_bool_cond_for_legacy_estimate',
