},

{ name => 'yb_lock_pk_single_rpc', type => 'bool', context => 'PGC_USERSET', group => 'QUERY_TUNING_OTHER',
  short_desc => 'Use single RPC to select and lock when PK is specified.',
  long_desc => 'If possible (no conflicting filters in the plan), use a single RPC to select and lock, when a locking clause is provided, in isolation levels REPEATABLE READ and READ COMMITTED.',
  variable => 'yb_lock_pk_single_rpc',
  boot_val => 'false',
},

