  boot_val => '0',
  min => '0',
  max => 'MAX_PARALLEL_WORKER_LIMIT',
},

{ name => 'autovacuum_max_workers', type => 'int', context => 'PGC_SIGHUP', group => 'VACUUM_AUTOVACUUM',
  short_desc => 'Sets the maximum number of simultaneously running autovacuum worker processes.',
