},

{ name => 'yb_locks_min_txn_age', type => 'int', context => 'PGC_USERSET', group => 'LOCK_MANAGEMENT',
  short_desc => 'Sets the minimum transaction age for results from pg_locks.',
  flags => 'GUC_UNIT_MS',
  variable => 'yb_locks_min_txn_age',
  boot_val => '1000',
  min => '0',
  max => 'INT_MAX',
},

{ name => 'yb_locks_txn_locks_per_tablet', type => 'int', context => 'PGC_USERSET', group => 'LOCK_MANAGEMENT',
