   Rows Removed by Index Recheck: 4
   Storage Table Read Requests: 2
   Storage Table Read Ops: 3
   Storage Table Rows Scanned: 4
   Storage Index Read Requests: 1
   Storage Index Read Ops: 3
   Storage Index Rows Scanned: 4
(9 rows)

-- Should return 1s
\set Q1 '/*+ IndexScan(t1) */'
\set Q2 '/*+ IndexScan(t1 i_nulltest_ba) */'
\set query ':P :Q SELECT a FROM nulltest t1 WHERE a IN (null, 1);'
\i :run_query
\set _echo_run_query :ECHO
\set ECHO none
