:P SELECT id, v FROM t_colocated WHERE v >= 10 AND v < 15 ORDER BY v;
$$ AS query \gset
\i :iter_P2
\set _echo_P :ECHO
\set ECHO none
                     QUERY PLAN                     
----------------------------------------------------
 Index Only Scan using t_colocated_v on t_colocated
   Index Cond: ((v >= 10) AND (v < 15))
