BEGIN ISOLATION LEVEL REPEATABLE READ;
WITH next AS (SELECT id FROM t_queue ORDER BY id LIMIT 3 FOR UPDATE SKIP LOCKED) UPDATE t_queue SET status = 'processing' WHERE id IN (SELECT id FROM next) RETURNING id, status;
 id |   status   
