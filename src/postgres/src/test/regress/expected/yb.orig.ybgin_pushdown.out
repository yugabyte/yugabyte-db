SELECT $$
:P SELECT * FROM gin_pushdown WHERE guid = '9' AND status <> '9';
$$ AS query \gset
\i :iter_P2
\set _echo_P :ECHO
\set ECHO none
                       QUERY PLAN                       
--------------------------------------------------------
 Index Scan using gin_pushdown_guid_key on gin_pushdown
   Index Cond: ((guid)::text = '9'::text)
   Storage Filter: ((status)::text <> '9'::text)
(3 rows)

 id | guid | status | json_content 
----+------+--------+--------------
(0 rows)

SELECT $$
:P SELECT * FROM gin_pushdown WHERE guid = '9' AND status = '9';
$$ AS query \gset
\i :iter_P2
\set _echo_P :ECHO
\set ECHO none
                       QUERY PLAN                       
--------------------------------------------------------
 Index Scan using gin_pushdown_guid_key on gin_pushdown
   Index Cond: ((guid)::text = '9'::text)
   Storage Filter: ((status)::text = '9'::text)
(3 rows)

 id | guid | status |              json_content               
----+------+--------+-----------------------------------------
 9  | 9    | 9      | {"refs": [{"val": "9"}, {"val": "10"}]}
(1 row)

-- Pushdown filter that goes with the index scan, since json_content is included
SELECT $$
:P SELECT * FROM gin_pushdown WHERE guid = '9' AND json_content->'refs'->0->'val' <> '"9"';
$$ AS query \gset
\i :iter_P2
\set _echo_P :ECHO
\set ECHO none
                                         QUERY PLAN                                         
--------------------------------------------------------------------------------------------
 Index Scan using gin_pushdown_guid_key on gin_pushdown
   Index Cond: ((guid)::text = '9'::text)
   Storage Filter: ((((json_content -> 'refs'::text) -> 0) -> 'val'::text) <> '"9"'::jsonb)
(3 rows)

 id | guid | status | json_content 
----+------+--------+--------------
(0 rows)

SELECT $$
:P SELECT * FROM gin_pushdown WHERE guid = '9' AND json_content->'refs'->0->'val' = '"9"';
$$ AS query \gset
\i :iter_P2
\set _echo_P :ECHO
