-- Hash join
set enable_mergejoin to false;
EXPLAIN (costs off)
SELECT pctest_h1.k, pctest_h2.k FROM pctest_h1 JOIN pctest_h2 USING (a, c) ORDER BY pctest_h1.k, pctest_h2.k;
