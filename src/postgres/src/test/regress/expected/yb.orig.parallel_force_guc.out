-- Hash join
set enable_mergejoin to false;
EXPLAIN (costs off)
SELECT pctest1.k, pctest2.k FROM pctest1 JOIN pctest2 USING (a, c)
  ORDER BY pctest1.k, pctest2.k;
                                   QUERY PLAN                                   
--------------------------------------------------------------------------------
 Gather Merge
   Workers Planned: 2
   ->  Sort
         Sort Key: pctest1.k, pctest2.k
         ->  Hash Join
               Hash Cond: ((pctest2.a = pctest1.a) AND (pctest2.c = pctest1.c))
               ->  Parallel Seq Scan on pctest2
               ->  Hash
                     ->  Index Scan using pctest1_pkey on pctest1
(9 rows)

