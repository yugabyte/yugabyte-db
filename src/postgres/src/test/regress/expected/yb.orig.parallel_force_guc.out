EXPLAIN (costs off)
WITH cte AS MATERIALIZED (
SELECT * FROM
  (SELECT pctest_h1.* FROM pctest_h1, pctest_h2
     WHERE pctest_h1.k = pctest_h2.k AND pctest_h1.c = pctest_h2.c) s1 JOIN
  (SELECT pctest_h2.* FROM pctest_h1, pctest_h2
     WHERE pctest_h1.k = pctest_h2.k AND pctest_h1.b = pctest_h2.b) s2 ON s1.b = s2.c)
SELECT * FROM cte ORDER BY 1, 5;
                                                 QUERY PLAN                                                 
------------------------------------------------------------------------------------------------------------
 Sort
   Sort Key: cte.k, cte.d
   CTE cte
     ->  Nested Loop
           ->  Gather
                 Workers Planned: 2
                 ->  Parallel Hash Join
                       Hash Cond: (pctest_h2_1.c = pctest_h1.b)
                       ->  Parallel Seq Scan on pctest_h2 pctest_h2_1
                       ->  Parallel Hash
                             ->  Hash Join
                                   Hash Cond: ((pctest_h2.k = pctest_h1.k) AND (pctest_h2.c = pctest_h1.c))
                                   ->  Parallel Seq Scan on pctest_h2
                                   ->  Hash
                                         ->  Seq Scan on pctest_h1
           ->  Index Scan using pctest_h1_pkey on pctest_h1 pctest_h1_1
                 Index Cond: (k = pctest_h2_1.k)
                 Storage Filter: (pctest_h2_1.b = b)
   ->  CTE Scan on cte
(19 rows)

WITH cte AS MATERIALIZED (
SELECT * FROM
  (SELECT pctest_h1.* FROM pctest_h1, pctest_h2
     WHERE pctest_h1.k = pctest_h2.k AND pctest_h1.c = pctest_h2.c) s1 JOIN
  (SELECT pctest_h2.* FROM pctest_h1, pctest_h2
     WHERE pctest_h1.k = pctest_h2.k AND pctest_h1.b = pctest_h2.b) s2 ON s1.b = s2.c)
