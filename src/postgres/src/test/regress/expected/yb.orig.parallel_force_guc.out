EXPLAIN (costs off)
SELECT * FROM
  (SELECT pctest1.* FROM pctest1, pctest2
     WHERE pctest1.k = pctest2.k AND pctest1.c = pctest2.c) s1 JOIN
  (SELECT pctest4.* FROM pctest1 pctest3, pctest2 pctest4
     WHERE pctest3.k = pctest4.k AND pctest3.b = pctest4.b) s2 ON s1.b = s2.c;
                                    QUERY PLAN                                     
-----------------------------------------------------------------------------------
 Gather
   Workers Planned: 2
   ->  Parallel Hash Join
         Hash Cond: (pctest1.b = pctest4.c)
         ->  Merge Join
               Merge Cond: (pctest1.k = pctest2.k)
               Join Filter: (pctest1.c = pctest2.c)
               ->  Parallel Index Scan using pctest1_pkey on pctest1
               ->  Materialize
                     ->  Index Scan using pctest2_pkey on pctest2
         ->  Parallel Hash
               ->  Merge Join
                     Merge Cond: (pctest3.k = pctest4.k)
                     Join Filter: (pctest3.b = pctest4.b)
                     ->  Parallel Index Scan using pctest1_pkey on pctest1 pctest3
                     ->  Materialize
                           ->  Index Scan using pctest2_pkey on pctest2 pctest4
(17 rows)

