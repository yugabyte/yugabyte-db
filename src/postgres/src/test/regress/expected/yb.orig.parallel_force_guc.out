-- Subquery
EXPLAIN (costs off)
SELECT x, d FROM
  (SELECT pctest_h1.* FROM pctest_h1, pctest_h2
     WHERE pctest_h1.k = pctest_h2.k AND pctest_h1.c = pctest_h2.c) ss RIGHT JOIN
  (values (15),(16),(17)) v(x) on ss.b = v.x ORDER BY x;
                                          QUERY PLAN                                          
----------------------------------------------------------------------------------------------
 Merge Left Join
   Merge Cond: ("*VALUES*".column1 = pctest_h1.b)
   ->  Sort
         Sort Key: "*VALUES*".column1
         ->  Values Scan on "*VALUES*"
   ->  Sort
         Sort Key: pctest_h1.b
         ->  Gather
               Workers Planned: 2
               ->  Parallel Hash Join
                     Hash Cond: ((pctest_h1.k = pctest_h2.k) AND (pctest_h1.c = pctest_h2.c))
                     ->  Parallel Seq Scan on pctest_h1
                     ->  Parallel Hash
                           ->  Parallel Seq Scan on pctest_h2
(14 rows)

