         ->  Hash Join
               Hash Cond: (t.k = t1.k)
               ->  Seq Scan on t
               ->  Hash
                     ->  Seq Scan on t1
         ->  Hash Join
               Hash Cond: (t_1.k = t2.k)
               ->  Seq Scan on t t_1
               ->  Hash
                     ->  Seq Scan on t2
(13 rows)

-- joins union all
