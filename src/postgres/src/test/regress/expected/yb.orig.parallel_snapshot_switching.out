-- Test with Gather Merge (sorted parallel output).
\set filename :abs_srcdir '/yb_commands/parallel_snapshot_switching_query_with_gather_merge.sql'
SET DEFAULT_TRANSACTION_ISOLATION = 'READ COMMITTED';
\i :filename
\getenv abs_srcdir PG_ABS_SRCDIR
\set pq_param :abs_srcdir '/yb_commands/parameterized_query.sql'
\i :pq_param
\set _echo_pq :ECHO
\set ECHO none
\set P1 'EXPLAIN (COSTS OFF)'
\set P2
-- The ORDER BY on the primary key with a parallel scan should produce a Gather Merge plan.
\set query ':P SELECT count(*) FROM (SELECT k FROM pss_test WHERE pss_snapshot_fn(k) = k ORDER BY k) t;'
BEGIN;
\i :iter_P2
\set _echo_P :ECHO
\set ECHO none
                      QUERY PLAN                      
------------------------------------------------------
 Aggregate
   ->  Gather Merge
         Workers Planned: 4
         ->  Sort
               Sort Key: pss_test.k
               ->  Parallel Seq Scan on pss_test
                     Filter: (pss_snapshot_fn(k) = k)
(7 rows)

 count 
-------
 10000
(1 row)

COMMIT;
-- Also run outside a transaction block.
\i :iter_P2
\set _echo_P :ECHO
\set ECHO none
                      QUERY PLAN                      
------------------------------------------------------
 Aggregate
   ->  Gather Merge
         Workers Planned: 4
         ->  Sort
               Sort Key: pss_test.k
               ->  Parallel Seq Scan on pss_test
                     Filter: (pss_snapshot_fn(k) = k)
(7 rows)

 count 
-------
 10000
(1 row)

