--
-- Should choose SERIAL append plan
--
EXPLAIN (COSTS off, SUMMARY off)
SELECT k1, k2, k3, count(*)
FROM (
    SELECT id, k1, k2, k3 FROM t1m t1 WHERE id BETWEEN 500000-(10/2-1) AND 500000+(10/2)
    UNION ALL
    SELECT -1, k1, k2, k3 FROM t1m t2 WHERE k1 <= 50
    UNION ALL
    SELECT -2, k1, k2, k3 FROM t1m t3 WHERE k1 IN (100, 200, 1000, 2000, 5000, 8000)
    UNION ALL
    SELECT -3, k1, k2, k3 FROM t1m t4 WHERE k1 IN (1000, 3000, 5000, 6000, 7000)
) v
GROUP BY k1, k2, k3
ORDER BY k1, k2, k3;
                                          QUERY PLAN                                           
-----------------------------------------------------------------------------------------------
 Sort
   Sort Key: "*SELECT* 1".k1, "*SELECT* 1".k2, "*SELECT* 1".k3
   ->  HashAggregate
         Group Key: "*SELECT* 1".k1, "*SELECT* 1".k2, "*SELECT* 1".k3
         ->  Append
               ->  Subquery Scan on "*SELECT* 1"
                     ->  Index Scan using t1m_pkey on t1m t1
                           Index Cond: ((id >= 499996) AND (id <= 500005))
               ->  Subquery Scan on "*SELECT* 2"
                     ->  Index Only Scan using t1m_k1k2k3 on t1m t2
                           Index Cond: (k1 <= 50)
               ->  Subquery Scan on "*SELECT* 3"
                     ->  Index Only Scan using t1m_k1k2k3 on t1m t3
                           Index Cond: (k1 = ANY ('{100,200,1000,2000,5000,8000}'::integer[]))
               ->  Subquery Scan on "*SELECT* 4"
                     ->  Index Only Scan using t1m_k1k2k3 on t1m t4
                           Index Cond: (k1 = ANY ('{1000,3000,5000,6000,7000}'::integer[]))
(17 rows)

