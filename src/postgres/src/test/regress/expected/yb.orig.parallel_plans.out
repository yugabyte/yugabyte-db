--
-- Should choose PARALLEL append + gather plan
--
EXPLAIN (COSTS off, SUMMARY off)
SELECT k1, k2, k3, count(*)
FROM (
    SELECT id, k1, k2, k3 FROM t1m t1 WHERE id BETWEEN 500000-(10/2-1) AND 500000+(10/2)
    UNION ALL
    SELECT -1, k1, k2, k3 FROM t1m t2 WHERE k3 = 5000
    UNION ALL
    SELECT -2, k1, k2, k3 FROM t1m t3 WHERE k2 = 2000
    UNION ALL
    SELECT -3, k1, k2, k3 FROM t1m t4 WHERE k1 = 3000
) v
GROUP BY k1, k2, k3
ORDER BY k1, k2, k3;
                                    QUERY PLAN                                     
-----------------------------------------------------------------------------------
 GroupAggregate
   Group Key: "*SELECT* 2".k1, "*SELECT* 2".k2, "*SELECT* 2".k3
   ->  Sort
         Sort Key: "*SELECT* 2".k1, "*SELECT* 2".k2, "*SELECT* 2".k3
         ->  Gather
               Workers Planned: 2
               ->  Parallel Append
                     ->  Subquery Scan on "*SELECT* 2"
                           ->  Parallel Index Only Scan using t1m_k1k2k3 on t1m t2
                                 Index Cond: (k3 = 5000)
                     ->  Subquery Scan on "*SELECT* 3"
                           ->  Parallel Index Only Scan using t1m_k1k2k3 on t1m t3
                                 Index Cond: (k2 = 2000)
                     ->  Subquery Scan on "*SELECT* 4"
                           ->  Parallel Index Only Scan using t1m_k1k2k3 on t1m t4
                                 Index Cond: (k1 = 3000)
                     ->  Subquery Scan on "*SELECT* 1"
                           ->  Parallel Index Scan using t1m_pkey on t1m t1
                                 Index Cond: ((id >= 499996) AND (id <= 500005))
(19 rows)

--
-- Should choose PARALLEL append + partial agg + gather MERGE plan
--
EXPLAIN (COSTS off, SUMMARY off)
SELECT id, k3, count(*), avg(length(v))
FROM (
    SELECT id, k1, k2, k3, v FROM t1m t1 WHERE id BETWEEN 500000-(10000/2-1) AND 500000+(10000/2)
    UNION ALL
    SELECT id, k1, k2, k3, v FROM t1m t2 WHERE k3 <= 100
    UNION ALL
    SELECT id, k1, k2, k3, v FROM t1m t3 WHERE k2 <= 100
    UNION ALL
    SELECT id, k1, k2, k3, v FROM t1m t4 WHERE k1 <= 100
) v
GROUP BY k3, id
ORDER BY k3, id;
                                      QUERY PLAN                                       
---------------------------------------------------------------------------------------
 Finalize GroupAggregate
   Group Key: "*SELECT* 2".k3, "*SELECT* 2".id
   ->  Gather Merge
         Workers Planned: 2
         ->  Sort
               Sort Key: "*SELECT* 2".k3, "*SELECT* 2".id
               ->  Partial HashAggregate
                     Group Key: "*SELECT* 2".k3, "*SELECT* 2".id
                     ->  Parallel Append
                           ->  Subquery Scan on "*SELECT* 2"
                                 ->  Parallel Index Scan using t1m_k1k2k3 on t1m t2
                                       Index Cond: (k3 <= 100)
                           ->  Subquery Scan on "*SELECT* 3"
                                 ->  Parallel Index Scan using t1m_k1k2k3 on t1m t3
                                       Index Cond: (k2 <= 100)
                           ->  Subquery Scan on "*SELECT* 4"
                                 ->  Parallel Index Scan using t1m_k1k2k3 on t1m t4
                                       Index Cond: (k1 <= 100)
                           ->  Subquery Scan on "*SELECT* 1"
                                 ->  Parallel Index Scan using t1m_pkey on t1m t1
                                       Index Cond: ((id >= 495001) AND (id <= 505000))
(21 rows)

