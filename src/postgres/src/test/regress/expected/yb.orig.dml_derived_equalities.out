EXPLAIN (COSTS OFF) SELECT /*+ NestLoop(u o) IndexScan(o) */ * FROM users u FULL JOIN orders_gen o ON o.user_id = u.id WHERE u.id = 50 AND o.user_id = 50;
                                  QUERY PLAN                                   
-------------------------------------------------------------------------------
 Nested Loop
   ->  Seq Scan on users u
