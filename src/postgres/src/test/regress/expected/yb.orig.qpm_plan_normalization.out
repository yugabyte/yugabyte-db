SELECT /* QPM NORMALIZE QUERY 4 */
	   'It''s a test string with a ''quoted'' word',
       '{"path": "C:\\Program Files\\App", "note": "Line1\nLine2"}'::jsonb,
	   E'{"text": "Hello\\nWorld", "quote": "O\'Reilly"}'::jsonb,
	   convert_to('Hello\nWorld', 'UTF8'),
	   '',
	   ''''
FROM simple_table1;
