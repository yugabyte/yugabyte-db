-----------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
 [                                                                                                                                                                                                                                                                                                                                                        +
   {                                                                                                                                                                                                                                                                                                                                                      +
     "Plan": {                                                                                                                                                                                                                                                                                                                                            +
       "Node Type": "Seq Scan",                                                                                                                                                                                                                                                                                                                           +
       "Parallel Aware": false,                                                                                                                                                                                                                                                                                                                           +
       "Async Capable": false,                                                                                                                                                                                                                                                                                                                            +
       "Relation Name": "simple_table1",                                                                                                                                                                                                                                                                                                                  +
       "Schema": "qpm_plan_normalization",                                                                                                                                                                                                                                                                                                                +
       "Alias": "st",                                                                                                                                                                                                                                                                                                                                     +
       "Output": ["(c1 + ?)", "?", "'?'::text", "(c3 || '?'::text)", "'?'::text", "(? + c2)", "'?'::timestamp without time zone", "?", "?::text", "CASE WHEN ((c1 + ?) < ?) THEN ? ELSE ? END", "sqrt(((c2 + ?))::double precision)", "?", "'?'::bytea", "'?'::numeric", "?", "'?'::numeric", "?", "?::numeric(6,2)", "'?'::numeric", "?::numeric(10,2)"],+
       "Storage Filter": "(st.c2 < ?)"                                                                                                                                                                                                                                                                                                                    +
     }                                                                                                                                                                                                                                                                                                                                                    +
   }                                                                                                                                                                                                                                                                                                                                                      +
 ]
(1 row)

/*+ HashJoin(st1 st2) Leading((st1 st2)) IndexScan(st1) SeqScan(st2) */
/* QPM NORMALIZE QUERY 2 */
SELECT SUM(st1.c1+5)
    FROM simple_table1 st1 LEFT JOIN (SELECT 1 c1, c2%9 c2, null c3 FROM simple_table1) st2
								ON st1.c1=st2.c1+1
	WHERE st1.c2<7 AND (st2.c2<>8 OR st2.c2 IS NULL);
 sum 
-----
   6
(1 row)

