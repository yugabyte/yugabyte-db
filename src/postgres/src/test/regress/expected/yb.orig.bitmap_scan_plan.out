-- Lower work_mem.  When the bitmap plan's estimated ybctid intermediate
-- would overflow work_mem, the planner inflates the bitmap cost by the
-- cost of a seq-scan fallback (no lossy bitmap in YB), pushing Q1/Q3 to
-- a single c-scan and Q5 to a seq scan.
set work_mem = '256kB';
select explain(3, query, expected) from queries order by id;
                                                         explain                                                         
