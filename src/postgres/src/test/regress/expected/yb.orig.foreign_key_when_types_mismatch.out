UPDATE parent SET v1 = :'trap_child_val' WHERE h = 1; -- should fail: cannot fit child column
ysqlsh:yb_commands/foreign_key_when_types_mismatch_helper.sql:93: ERROR:  smallint out of range
CONTEXT:  SQL statement "UPDATE ONLY "public"."child" SET "v1" = $1 WHERE $2 OPERATOR(pg_catalog.=) "v1""
SELECT count(*) FROM child WHERE h = 100002 AND v1 = :'v1';
