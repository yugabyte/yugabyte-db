CREATE TABLE child(h INT PRIMARY KEY, v1 TEXT, FOREIGN KEY(v1) REFERENCES parent(v1)
  ON DELETE CASCADE ON UPDATE CASCADE) SPLIT INTO 1 TABLETS;
