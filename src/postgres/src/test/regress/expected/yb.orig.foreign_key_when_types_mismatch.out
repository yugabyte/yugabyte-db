--
-- Testing foreign key constraint check when types mismatch.
--
-- This test ensures that the foreign key constraint check uses the
-- batched DocDB lookup path when types mismatch.
--
-- Templated type pairs run yb_commands/foreign_key_when_types_mismatch_helper.sql
-- after CREATE TABLE, CREATE UNIQUE INDEX parent_v1_key ... SPLIT INTO 1 TABLETS,
-- and setting v1-v5, trap_parent_val, trap_child_val.
-- The helper covers: CASCADE, multi row insert, COPY, out of range,
-- SET NULL, NO ACTION deferrable (including deferred COMMIT fail), RESTRICT deferrable,
-- partial null composite update, SET DEFAULT composite, and MATCH FULL.
--
-- Covered type pairs (each runs the helper via \i):
--  * int2 -> int4, int4 -> int8, int2 -> int8 (widening, implicit cast)
--  * int4 -> int2, int8 -> int2, int8 -> int4 (narrowing, assignment cast)
--  * int2 -> bigserial, int4 -> bigserial, int8 -> bigserial
--  * int2 -> serial, int4 -> serial, int2 -> smallserial, smallserial -> bigserial
--  * text -> varchar, varchar -> text
--
-- Inline-only (structural or catalog-specific; not in helper):
--  * VARCHAR(3)/TEXT length overflow (cannot use generic parent/child shape)
--  * composite FK (3+ columns), multi-parent FK, partitioned/attach partition
--  * pg_constraint/pg_cast/pg_proc cache, ON CONFLICT, self-referential FK
--
\set VERBOSITY default
SHOW yb_enable_fkey_batched_docdb_lookup_when_types_mismatch; -- should be true
 yb_enable_fkey_batched_docdb_lookup_when_types_mismatch 
---------------------------------------------------------
 on
(1 row)

-- int2 to int4
CREATE TABLE parent(h INT PRIMARY KEY, v1 INT) SPLIT INTO 1 TABLETS;
CREATE UNIQUE INDEX parent_v1_key ON parent(v1) SPLIT INTO 1 TABLETS;
CREATE TABLE child(h INT PRIMARY KEY, v1 SMALLINT, FOREIGN KEY(v1) REFERENCES parent(v1)
  ON DELETE CASCADE ON UPDATE CASCADE) SPLIT INTO 1 TABLETS;
\set v1 456
\set v2 458
\set v3 457
\set v4 460
\set v5 999
\set trap_parent_val -32767
\set trap_child_val 32769
\i yb_commands/foreign_key_when_types_mismatch_helper.sql
--
-- Helper for yb.orig.foreign_key_when_types_mismatch.sql.
--
-- Driver must CREATE parent(h, v1) and child(h, v1) with ON DELETE/UPDATE CASCADE.
-- parent(v1) must be backed by parent_v1_key with SPLIT INTO 1 TABLETS so FK batched
-- lookups hit a single tablet. Then set psql variables:
--   v1, v2, v3, v4, v5
--   trap_parent_val, trap_child_val
--
-- Each scenario inserts its own rows (parent h from 1, child h from 100001),
-- then TRUNCATEs both tables. The helper ends by dropping parent and child.
--
-- Scenarios (in order):
--   CASCADE, multi row insert, COPY, out of range insert/update,
--   SET NULL, NO ACTION deferrable (including COMMIT fail),
--   RESTRICT deferrable, partial null composite update, SET DEFAULT composite, MATCH FULL
--
-- CASCADE
INSERT INTO parent VALUES (1, :'v1');
INSERT INTO child VALUES (1, :'v1'); -- warm up catalog cache
DELETE FROM child WHERE h = 1; -- undo changes due to warm up
BEGIN TRANSACTION ISOLATION LEVEL SERIALIZABLE;
EXPLAIN (DIST, ANALYZE, COSTS OFF) INSERT INTO child VALUES (100001, :'v1');
                  QUERY PLAN                   
-----------------------------------------------
 Insert on child (actual rows=0 loops=1)
   ->  Result *RESULT* (actual rows=1 loops=1)
         Storage Table Write Requests: 1
 Trigger for constraint child_v1_fkey: calls=1
 Storage Read Requests: 1
 Storage Read Ops: 1
 Storage Rows Scanned: 1
 Storage Write Requests: 1
 Storage Flush Requests: 1
(9 rows)

COMMIT;
SELECT count(*) FROM child;
 count 
-------
     1
(1 row)

ALTER TABLE child DROP CONSTRAINT child_v1_fkey;
ALTER TABLE child ADD CONSTRAINT child_v1_fkey FOREIGN KEY(v1) REFERENCES parent(v1)
  ON DELETE CASCADE ON UPDATE CASCADE;
UPDATE parent SET v1 = :'v3' WHERE h = 1;
SELECT count(*) FROM child WHERE h = 100001 AND v1 = :'v3';
 count 
-------
     1
(1 row)

DELETE FROM parent WHERE h = 1;
SELECT count(*) FROM child;
 count 
-------
     0
(1 row)

INSERT INTO parent VALUES (1, :'v1');
INSERT INTO child VALUES (100002, :'v5'); -- should fail: no matching parent key
ysqlsh:yb_commands/foreign_key_when_types_mismatch_helper.sql:35: ERROR:  insert or update on table "child" violates foreign key constraint "child_v1_fkey"
DETAIL:  Key (v1)=(999) is not present in table "parent".
SELECT count(*) FROM child;
 count 
-------
     0
(1 row)

TRUNCATE child, parent;
-- multi row insert
INSERT INTO parent VALUES (1, :'v1'), (2, :'v2'), (3, :'v3');
INSERT INTO child VALUES (1, :'v1'); -- warm up catalog cache
DELETE FROM child WHERE h = 1; -- undo changes due to warm up
-- three distinct keys: run first with empty child for one batched FK read
BEGIN TRANSACTION ISOLATION LEVEL SERIALIZABLE;
EXPLAIN (DIST, ANALYZE, COSTS OFF) INSERT INTO child VALUES
  (100007, :'v1'), (100008, :'v2'), (100009, :'v3');
                       QUERY PLAN                        
---------------------------------------------------------
 Insert on child (actual rows=0 loops=1)
   ->  Values Scan on "*VALUES*" (actual rows=3 loops=1)
         Storage Table Write Requests: 3
 Trigger for constraint child_v1_fkey: calls=3
 Storage Read Requests: 1
 Storage Read Ops: 2
 Storage Rows Scanned: 3
 Storage Write Requests: 3
 Storage Flush Requests: 1
(9 rows)

COMMIT;
SELECT count(*) FROM child;
 count 
-------
     3
(1 row)

-- same key repeated
BEGIN TRANSACTION ISOLATION LEVEL SERIALIZABLE;
EXPLAIN (DIST, ANALYZE, COSTS OFF) INSERT INTO child VALUES
  (100004, :'v1'), (100005, :'v1'), (100006, :'v1');
                       QUERY PLAN                        
---------------------------------------------------------
 Insert on child (actual rows=0 loops=1)
   ->  Values Scan on "*VALUES*" (actual rows=3 loops=1)
         Storage Table Write Requests: 3
 Trigger for constraint child_v1_fkey: calls=3
 Storage Read Requests: 1
 Storage Read Ops: 1
 Storage Rows Scanned: 1
 Storage Write Requests: 3
 Storage Flush Requests: 1
(9 rows)

COMMIT;
SELECT count(*) FROM child;
 count 
-------
     6
(1 row)

-- two distinct keys with duplicate
BEGIN TRANSACTION ISOLATION LEVEL SERIALIZABLE;
EXPLAIN (DIST, ANALYZE, COSTS OFF) INSERT INTO child VALUES
  (100001, :'v1'), (100002, :'v1'), (100003, :'v2');
                       QUERY PLAN                        
---------------------------------------------------------
 Insert on child (actual rows=0 loops=1)
   ->  Values Scan on "*VALUES*" (actual rows=3 loops=1)
         Storage Table Write Requests: 3
 Trigger for constraint child_v1_fkey: calls=3
 Storage Read Requests: 1
 Storage Read Ops: 2
 Storage Rows Scanned: 2
 Storage Write Requests: 3
 Storage Flush Requests: 1
(9 rows)

COMMIT;
SELECT count(*) FROM child;
 count 
-------
     9
(1 row)

TRUNCATE child, parent;
-- COPY
INSERT INTO parent VALUES (1, :'v1'), (2, :'v2');
\set copy_cmd 'printf "100001\t' :v1 '\n100002\t' :v2 '\n"'
COPY child FROM PROGRAM :'copy_cmd';
SELECT count(*) FROM child;
 count 
-------
     2
(1 row)

\set copy_cmd 'printf "100003\t' :v1 '\n100004\t' :v2 '\n100005\t' :v5 '\n"'
COPY child FROM PROGRAM :'copy_cmd';
ysqlsh:yb_commands/foreign_key_when_types_mismatch_helper.sql:69: ERROR:  insert or update on table "child" violates foreign key constraint "child_v1_fkey"
DETAIL:  Key (v1)=(999) is not present in table "parent".
CONTEXT:  COPY child, line 4: ""
-- should fail: no matching parent key
SELECT count(*) FROM child;
 count 
-------
     2
(1 row)

INSERT INTO parent VALUES (3, :'trap_parent_val');
\set copy_cmd 'printf "100006\t' :trap_child_val '\n"'
COPY child FROM PROGRAM :'copy_cmd';
ysqlsh:yb_commands/foreign_key_when_types_mismatch_helper.sql:74: ERROR:  value "32769" is out of range for type smallint
